# ===== Automator 配置示例 =====
# 复制为 .env 后修改

# ---- 服务 ----
AUTOMATOR_HOST=0.0.0.0
AUTOMATOR_PORT=8000
AUTOMATOR_LOG_LEVEL=INFO

# ---- 设备 ----
# 单机模式下默认连接的设备序列号(留空则自动选第一台)
AUTOMATOR_DEVICE_SERIAL=
# atx-agent 端口(默认 7912)
AUTOMATOR_ATX_PORT=7912

# ---- 存储 ----
AUTOMATOR_DB_URL=sqlite:///data/automator.db
# 截图目录
AUTOMATOR_SCREENSHOT_DIR=data/screenshots

# ---- 任务执行 ----
# 执行线程池大小
AUTOMATOR_EXECUTOR_WORKERS=4
# 步骤默认超时(秒)
AUTOMATOR_STEP_TIMEOUT=30

# ---- LLM(预留,本期不使用)----
# AUTOMATOR_LLM_PROVIDER=OpenAI
# AUTOMATOR_LLM_API_KEY=
# AUTOMATOR_LLM_MODEL=gpt-4o
